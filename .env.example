# Firebase Configuration
# Get these values from your Firebase project console (Project Settings > General)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# Firebase Admin SDK (Server-side)
# Used for server-side Firebase Admin operations
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"

# Slack OAuth Configuration  
# Create a Slack app at https://api.slack.com/apps
# Required OAuth scopes: channels:read, chat:write, users:read, team:read
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret

# Slack OAuth Redirect URI
# Must match the redirect URI registered in your Slack app
# Development: http://localhost:3000/api/auth/slack/callback
# Production: https://yourdomain.com/api/auth/slack/callback
SLACK_REDIRECT_URI=http://localhost:3000/api/auth/slack/callback

# Application Configuration
# Base URL of your application (used for OAuth redirects)
NEXTAUTH_URL=http://localhost:3000

# Security
# Random string used for session encryption and CSRF protection
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_secret_string_32_chars_minimum

# Firebase Emulator Configuration (Development)
# Set to "true" to use Firebase emulators instead of production Firebase
USE_FIREBASE_EMULATOR=false
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# Slack API Configuration
# Rate limiting and retry configuration for Slack API calls
SLACK_API_RATE_LIMIT_PER_MINUTE=60
SLACK_API_MAX_RETRIES=3
SLACK_API_RETRY_DELAY_MS=1000

# Application Business Rules
# Maximum number of channels per channel list (spec requirement)
MAX_CHANNELS_PER_LIST=100
# Maximum message length (Slack API limit)
MAX_MESSAGE_LENGTH=4000
# Maximum concurrent message sending operations
MAX_CONCURRENT_SENDS=10

# Logging Configuration
LOG_LEVEL=info
# Set to "true" to enable debug logging for development
ENABLE_DEBUG_LOGGING=false

# Environment
NODE_ENV=development

# Next.js Configuration
# Set to "1" to disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1
